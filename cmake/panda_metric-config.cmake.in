@PACKAGE_INIT@

include(CMakeFindDependencyMacro)
set(PANDA_METRIC_BUNDLED_BLAZE @METRIC_INSTALL_BUNDLED_BLAZE@)
set(PANDA_METRIC_BUNDLED_NLOHMANN_JSON @METRIC_INSTALL_BUNDLED_NLOHMANN_JSON@)
set(PANDA_METRIC_BUNDLED_CEREAL @METRIC_INSTALL_BUNDLED_CEREAL@)

if (NOT PANDA_METRIC_BUNDLED_BLAZE)
    find_dependency(blaze 3.8)
endif ()
if (NOT PANDA_METRIC_BUNDLED_NLOHMANN_JSON)
    find_dependency(nlohmann_json)
endif ()
if (NOT PANDA_METRIC_BUNDLED_CEREAL)
    find_dependency(cereal)
endif ()

include("${CMAKE_CURRENT_LIST_DIR}/@PROJECT_NAME@-targets.cmake")
check_required_components("@PROJECT_NAME@")
